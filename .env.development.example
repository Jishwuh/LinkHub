# Local development environment (works with docker-compose.dev.yml)
NODE_ENV=development
PORT=3000
PUBLIC_DOMAIN=localhost:3000
SESSION_SECRET=dev-session-secret-change-me
TRUST_PROXY=0

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
SEED_DEMO_DATA=true

BCRYPT_ROUNDS=10

# Abuse + safety controls (dev-friendly defaults)
LIKE_RATE_LIMIT_WINDOW_MS=60000
LIKE_RATE_LIMIT_MAX=20
REDIRECT_RATE_LIMIT_WINDOW_MS=60000
REDIRECT_RATE_LIMIT_MAX=120
VIEW_COUNT_THROTTLE_SECONDS=120
VIEW_COUNT_RETENTION_DAYS=14

DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=linkhub
DB_PASSWORD=linkhub_password
DB_NAME=linkhub_dev
