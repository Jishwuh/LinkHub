# LinkHub environment variables

# Core
NODE_ENV=production
PORT=3000
PUBLIC_DOMAIN=example.com
SESSION_SECRET=replace-with-a-long-random-secret
TRUST_PROXY=1

# Admin seed (first run only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Optional demo data seeding (set true for local visual preview)
SEED_DEMO_DATA=false

# Password hashing cost
BCRYPT_ROUNDS=12

# Abuse + safety controls
LIKE_RATE_LIMIT_WINDOW_MS=60000
LIKE_RATE_LIMIT_MAX=20
REDIRECT_RATE_LIMIT_WINDOW_MS=60000
REDIRECT_RATE_LIMIT_MAX=120
VIEW_COUNT_THROTTLE_SECONDS=300
VIEW_COUNT_RETENTION_DAYS=30

# Database (MySQL/MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
