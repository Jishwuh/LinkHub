{
  "name": "linkhub",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "start": "node server.cjs",
    "dev": "nodemon scripts/dev-server.cjs",
    "dev:db:up": "docker compose -f docker-compose.dev.yml up -d db",
    "dev:db:down": "docker compose -f docker-compose.dev.yml down",
    "check": "node --check server.cjs && node --check scripts/dev-server.cjs && node --check public/js/admin.js && node --check public/js/index.js",
    "test": "node --test"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "multer": "^2.0.2",
    "mysql2": "^3.9.7",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "main": "server.cjs"
}
