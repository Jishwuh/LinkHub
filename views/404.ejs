<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>404 | LinkHub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/static/css/site.css" />
</head>

<body>
  <div id="bg">
    <% const ytId = (settings && settings.bg_youtube_id ? String(settings.bg_youtube_id) : '').trim(); %>
      <% if (ytId) { %>
        <div class="video-bg">
          <iframe
            src="https://www.youtube-nocookie.com/embed/<%= ytId %>?autoplay=1&mute=1&controls=0&loop=1&playlist=<%= ytId %>&modestbranding=1&playsinline=1&rel=0"
            title="Background"
            allow="autoplay; encrypted-media; picture-in-picture"
            referrerpolicy="strict-origin-when-cross-origin"></iframe>
        </div>
        <% } %>
          <div class="overlay"></div>
  </div>

  <div class="container notfound-wrap">
    <div class="cardy">
      <h1>Page not found</h1>
      <p>The page you requested does not exist.</p>
      <a class="cta" href="/">Go to home</a>
    </div>
  </div>
</body>

</html>
