<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Admin</title>
  <link rel="stylesheet" href="/static/css/site.css">
</head>

<body class="admin">
  <div class="container">
    <input type="hidden" id="csrf-token" value="<%= csrfToken %>">

    <div class="admin-topbar">
      <h1>Admin Dashboard</h1>
      <form method="POST" action="/admin/logout" class="inline-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="btn-secondary" type="submit">Log out</button>
      </form>
    </div>

    <div id="admin-toast" class="admin-toast" role="status" aria-live="polite"></div>

    <form class="form form-wide settings-shell" id="settings-form" method="POST" action="/admin/settings" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="settings-header">
        <div>
          <h2>Site Settings</h2>
          <p class="muted">Edit one section at a time. Preview updates instantly before saving.</p>
        </div>
        <button type="submit" class="settings-save">Save settings</button>
      </div>

      <div class="settings-tabs" role="tablist" aria-label="Settings Sections">
        <button type="button" class="settings-tab active" data-tab="profile" aria-selected="true">Profile</button>
        <button type="button" class="settings-tab" data-tab="background" aria-selected="false">Background</button>
        <button type="button" class="settings-tab" data-tab="design" aria-selected="false">Design</button>
        <button type="button" class="settings-tab" data-tab="share" aria-selected="false">Share</button>
      </div>

      <div class="settings-layout">
        <div class="settings-main">
          <section class="settings-panel" data-panel="profile">
            <h3>Profile Basics</h3>
            <div class="grid">
              <label>Site title<input name="site_title" value="<%= settings.site_title || '' %>"></label>
              <label>Handle<input name="handle" value="<%= settings.handle || '' %>"></label>
              <label>Display name<input name="display_name" value="<%= settings.display_name || '' %>"></label>
              <label>
                Theme color
                <div class="inline-color-picker">
                  <input name="theme_color" id="theme-color" class="color-input" type="color" value="<%= settings.theme_color || '#ff4d6d' %>">
                  <span id="theme-color-preview" class="color-chip color-chip-lg" title="<%= settings.theme_color || '#ff4d6d' %>"></span>
                </div>
              </label>
            </div>
            <label>Bio<textarea name="bio" rows="4"><%= settings.bio || '' %></textarea></label>

            <div class="grid">
              <label>Avatar file<input type="file" name="avatar" accept="image/png,image/jpeg,image/webp,image/gif"></label>
              <label>Avatar emoji (fallback)<input name="avatar_emoji" value="<%= settings.avatar_emoji || '🙂' %>"></label>
            </div>
          </section>

          <section class="settings-panel" data-panel="background" hidden>
            <h3>Background Mode</h3>
            <div class="grid compact-grid">
              <label>
                <span class="label-with-tip">Background mode
                  <span class="field-tip" tabindex="0" data-tip="Choose the visual engine for your background.">?</span>
                </span>
                <select name="background_mode" id="background-mode">
                  <option value="youtube" <%= settings.background_mode === 'youtube' ? 'selected' : '' %>>YouTube</option>
                  <option value="image" <%= settings.background_mode === 'image' ? 'selected' : '' %>>Image</option>
                  <option value="video" <%= settings.background_mode === 'video' ? 'selected' : '' %>>Video</option>
                  <option value="gradient" <%= settings.background_mode === 'gradient' ? 'selected' : '' %>>Gradient</option>
                  <option value="particles" <%= settings.background_mode === 'particles' ? 'selected' : '' %>>JS Particles</option>
                </select>
              </label>
            </div>

            <div class="grid bg-mode-group" data-bg-visible="youtube">
              <label>
                <span class="label-with-tip">YouTube ID
                  <span class="field-tip" tabindex="0" data-tip="Paste only the video ID, not the full URL.">?</span>
                </span>
                <input name="bg_youtube_id" value="<%= settings.bg_youtube_id || '' %>" placeholder="dQw4w9WgXcQ">
              </label>
            </div>

            <div class="grid bg-mode-group" data-bg-visible="image">
              <label>Background image URL<input name="background_image_url" type="url" value="<%= settings.background_image_url || '' %>" placeholder="https://.../image.jpg"></label>
            </div>

            <div class="grid bg-mode-group" data-bg-visible="video">
              <label>Background video URL<input name="background_video_url" type="url" value="<%= settings.background_video_url || '' %>" placeholder="https://.../video.mp4"></label>
            </div>

            <div class="grid bg-mode-group" data-bg-visible="image,video">
              <label>
                <span class="label-with-tip">Upload media
                  <span class="field-tip" tabindex="0" data-tip="Image mode accepts image files. Video mode accepts video files.">?</span>
                </span>
                <input type="file" name="background_media_file" accept="image/png,image/jpeg,image/webp,image/gif,video/mp4,video/webm,video/ogg">
              </label>
            </div>

            <div class="grid bg-mode-group" data-bg-visible="gradient">
              <label>
                <span class="label-with-tip">Gradient preset
                  <span class="field-tip" tabindex="0" data-tip="Color palette for a static background.">?</span>
                </span>
                <select name="background_gradient">
                  <option value="sunset" <%= settings.background_gradient === 'sunset' ? 'selected' : '' %>>Sunset</option>
                  <option value="ocean" <%= settings.background_gradient === 'ocean' ? 'selected' : '' %>>Ocean</option>
                  <option value="forest" <%= settings.background_gradient === 'forest' ? 'selected' : '' %>>Forest</option>
                  <option value="neon" <%= settings.background_gradient === 'neon' ? 'selected' : '' %>>Neon</option>
                  <option value="midnight" <%= settings.background_gradient === 'midnight' ? 'selected' : '' %>>Midnight</option>
                </select>
              </label>
            </div>

            <div class="grid bg-mode-group" data-bg-visible="image,gradient">
              <label>
                <span class="label-with-tip">Pattern overlay
                  <span class="field-tip" tabindex="0" data-tip="Adds subtle texture over image or gradient backgrounds.">?</span>
                </span>
                <select name="background_pattern">
                  <option value="none" <%= settings.background_pattern === 'none' ? 'selected' : '' %>>None</option>
                  <option value="grid" <%= settings.background_pattern === 'grid' ? 'selected' : '' %>>Grid</option>
                  <option value="dots" <%= settings.background_pattern === 'dots' ? 'selected' : '' %>>Dots</option>
                  <option value="noise" <%= settings.background_pattern === 'noise' ? 'selected' : '' %>>Noise</option>
                </select>
              </label>
            </div>

            <div class="grid bg-mode-group" data-bg-visible="youtube,image,video">
              <label>
                <span class="label-with-tip">Blur strength px
                  <span class="field-tip" tabindex="0" data-tip="Softens media backgrounds for better readability.">?</span>
                </span>
                <input name="background_blur" type="number" min="0" max="20" step="0.5" value="<%= settings.background_blur %>">
              </label>
            </div>

            <div class="grid bg-mode-group" data-bg-visible="particles">
              <label>
                <span class="label-with-tip">Particle density
                  <span class="field-tip" tabindex="0" data-tip="How many particles appear on screen at once.">?</span>
                </span>
                <input name="particles_density" type="number" min="20" max="180" step="1" value="<%= settings.particles_density %>">
              </label>
              <label>
                <span class="label-with-tip">Particle speed
                  <span class="field-tip" tabindex="0" data-tip="How fast particles drift. Lower is calmer.">?</span>
                </span>
                <input name="particles_speed" type="number" min="0.2" max="3" step="0.1" value="<%= settings.particles_speed %>">
              </label>
            </div>

            <div class="grid compact-grid bg-mode-group" data-bg-visible="youtube,image,video,gradient,particles">
              <label>
                <span class="label-with-tip">Overlay opacity (0 to 0.9)
                  <span class="field-tip" tabindex="0" data-tip="Darkens the background to improve readability.">?</span>
                </span>
                <input name="overlay_opacity" type="number" min="0" max="0.9" step="0.05" value="<%= settings.overlay_opacity %>">
              </label>
            </div>
          </section>

          <section class="settings-panel" data-panel="design" hidden>
            <h3>Design System</h3>
            <div class="grid">
              <label>
                <span class="label-with-tip">Link layout
                  <span class="field-tip" tabindex="0" data-tip="Changes how link buttons are arranged on your page.">?</span>
                </span>
                <select name="link_layout">
                  <option value="list" <%= settings.link_layout === 'list' ? 'selected' : '' %>>List</option>
                  <option value="grid" <%= settings.link_layout === 'grid' ? 'selected' : '' %>>Grid</option>
                  <option value="compact" <%= settings.link_layout === 'compact' ? 'selected' : '' %>>Compact</option>
                  <option value="table" <%= settings.link_layout === 'table' ? 'selected' : '' %>>Table</option>
                </select>
              </label>
              <label>
                <span class="label-with-tip">Button style
                  <span class="field-tip" tabindex="0" data-tip="Shape and visual feel of every button.">?</span>
                </span>
                <select name="button_style">
                  <option value="rounded" <%= settings.button_style === 'rounded' ? 'selected' : '' %>>Rounded</option>
                  <option value="pill" <%= settings.button_style === 'pill' ? 'selected' : '' %>>Pill</option>
                  <option value="square" <%= settings.button_style === 'square' ? 'selected' : '' %>>Square</option>
                  <option value="glass" <%= settings.button_style === 'glass' ? 'selected' : '' %>>Glass</option>
                </select>
              </label>
              <label>
                <span class="label-with-tip">Font theme
                  <span class="field-tip" tabindex="0" data-tip="Changes typography personality across your page.">?</span>
                </span>
                <select name="font_theme">
                  <option value="modern" <%= settings.font_theme === 'modern' ? 'selected' : '' %>>Modern</option>
                  <option value="editorial" <%= settings.font_theme === 'editorial' ? 'selected' : '' %>>Editorial</option>
                  <option value="rounded" <%= settings.font_theme === 'rounded' ? 'selected' : '' %>>Rounded</option>
                  <option value="mono" <%= settings.font_theme === 'mono' ? 'selected' : '' %>>Monospace</option>
                </select>
              </label>
              <label>
                <span class="label-with-tip">Animation style
                  <span class="field-tip" tabindex="0" data-tip="Controls how much motion users see.">?</span>
                </span>
                <select name="animation_style">
                  <option value="none" <%= settings.animation_style === 'none' ? 'selected' : '' %>>None</option>
                  <option value="subtle" <%= settings.animation_style === 'subtle' ? 'selected' : '' %>>Subtle</option>
                  <option value="energetic" <%= settings.animation_style === 'energetic' ? 'selected' : '' %>>Energetic</option>
                </select>
              </label>
              <label>Like emoji<input name="like_emoji" value="<%= settings.like_emoji || '❤' %>"></label>
              <label>Share emoji<input name="share_emoji" value="<%= settings.share_emoji || '🔗' %>"></label>
            </div>
          </section>

          <section class="settings-panel" data-panel="share" hidden>
            <h3>Open Graph and Share</h3>
            <div class="grid">
              <label>Page title<input name="page_title" value="<%= settings.page_title || '' %>" placeholder="Embed title"></label>
              <label>Canonical URL<input name="site_url" type="url" value="<%= settings.site_url || '' %>" placeholder="https://yourdomain.com"></label>
            </div>
            <label>Embed description<textarea name="og_description" rows="3"><%= settings.og_description || '' %></textarea></label>
            <div class="grid">
              <label>OG image URL<input name="og_image" type="url" value="<%= settings.og_image || '' %>" placeholder="https://.../image.jpg"></label>
              <label>Upload OG image<input type="file" name="og_image_file" accept="image/png,image/jpeg,image/webp,image/gif"></label>
            </div>
            <label>Footer HTML<textarea name="footer_html" rows="3"><%= settings.footer_html || '' %></textarea></label>
          </section>
        </div>

        <aside class="settings-sidebar">
          <div class="preview-card">
            <h3>Live Preview</h3>
            <p class="muted small">This updates before you save so you can compare styles quickly.</p>
            <div
              id="design-preview"
              class="design-preview"
              data-initial-font="<%= settings.font_theme %>"
              data-initial-layout="<%= settings.link_layout %>"
              data-initial-button="<%= settings.button_style %>"
              data-initial-animation="<%= settings.animation_style %>"
              data-initial-mode="<%= settings.background_mode %>"
              data-initial-gradient="<%= settings.background_gradient %>"
              data-initial-pattern="<%= settings.background_pattern %>">
              <div id="design-preview-bg" class="design-preview-bg"></div>
              <div id="design-preview-overlay" class="design-preview-overlay"></div>
              <div class="design-preview-content">
                <div class="design-preview-handle" id="preview-handle"><%= settings.handle || '@handle' %></div>
                <div class="design-preview-name" id="preview-name"><%= settings.display_name || 'Display Name' %></div>
                <div class="design-preview-bio" id="preview-bio">Previewing fonts, layouts, button styles, and background behavior.</div>
                <div class="design-preview-actions">
                  <span id="preview-like"><%= settings.like_emoji || '❤' %> 124</span>
                  <span id="preview-share"><%= settings.share_emoji || '🔗' %></span>
                </div>
                <div id="design-preview-links" class="design-preview-links">
                  <div class="preview-link">GitHub</div>
                  <div class="preview-link">Portfolio</div>
                  <div class="preview-link">Contact</div>
                </div>
              </div>
            </div>
          </div>
        </aside>
      </div>

      <div class="settings-footer">
        <button type="submit" class="settings-save">Save settings</button>
      </div>
    </form>

    <details class="admin-accordion" open>
      <summary>
        <span>Links</span>
        <button type="button" class="btn-secondary create-new-btn" id="link-create-btn">Create New</button>
      </summary>
      <section class="card section-card">
        <div class="links-help muted">Drag using the handle to reorder. Hover color chips to view exact hex.</div>
        <div id="links-admin-list" class="links-admin-list" data-csrf="<%= csrfToken %>">
          <% links.forEach((l, idx) => { %>
            <article
              class="link-admin-item <%= l.is_visible ? '' : 'is-hidden-link' %>"
              draggable="true"
              data-id="<%= l.id %>"
              data-title="<%= l.title %>"
              data-url="<%= l.url %>"
              data-icon="<%= l.icon_key || '' %>"
              data-color="<%= l.color_hex || '' %>"
              data-order="<%= l.order_index %>"
              data-visible="<%= l.is_visible ? '1' : '0' %>">
              <button type="button" class="icon-action drag-handle" data-action="drag" title="Drag to reorder" aria-label="Drag to reorder">≡</button>
              <div class="link-admin-main">
                <div class="link-admin-title"><%= l.title %></div>
                <a class="link-admin-url" href="<%= l.url %>" target="_blank" rel="noopener noreferrer"><%= l.url %></a>
              </div>
              <div class="link-admin-meta">
                <span class="order-badge" title="Order">#<%= idx + 1 %></span>
                <% if (l.icon_key) { %><span class="link-pill" title="Icon key"><%= l.icon_key %></span><% } else { %><span class="link-pill" hidden></span><% } %>
                <span class="color-chip" data-color="<%= l.color_hex || '' %>" title="<%= l.color_hex || '#2a2a2a' %>"></span>
              </div>
              <div class="link-admin-actions">
                <button type="button" class="icon-action" data-action="edit" title="Edit link">Edit</button>
                <button type="button" class="icon-action" data-action="utm" title="Build tracked URL">Track</button>
                <button type="button" class="icon-action" data-action="toggle" title="Toggle visibility"><%= l.is_visible ? 'Hide' : 'Show' %></button>
                <button type="button" class="icon-action danger" data-action="delete" title="Delete link">Del</button>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
    </details>

    <details class="admin-accordion">
      <summary>
        <span>Custom Embeds</span>
        <button type="button" class="btn-secondary create-new-btn" id="embed-create-btn">Create New</button>
      </summary>
      <section class="card section-card">
        <div class="links-help muted">Drag to reorder embeds. Toggle visibility without leaving this view.</div>
        <div id="embeds-admin-list" class="links-admin-list" data-csrf="<%= csrfToken %>">
          <% embeds.forEach((e, idx) => { %>
            <article
              class="link-admin-item <%= e.is_visible ? '' : 'is-hidden-link' %>"
              draggable="true"
              data-id="<%= e.id %>"
              data-title="<%= e.title %>"
              data-html="<%= safeJsonForAttr(e.embed_html) %>"
              data-order="<%= e.order_index %>"
              data-visible="<%= e.is_visible ? '1' : '0' %>">
              <button type="button" class="icon-action drag-handle" data-action="drag" title="Drag to reorder" aria-label="Drag to reorder">≡</button>
              <div class="link-admin-main">
                <div class="link-admin-title"><%= e.title %></div>
                <div class="link-admin-url">Embed block</div>
              </div>
              <div class="link-admin-meta">
                <span class="order-badge" title="Order">#<%= idx + 1 %></span>
              </div>
              <div class="link-admin-actions">
                <button type="button" class="icon-action" data-action="edit" title="Edit embed">Edit</button>
                <button type="button" class="icon-action" data-action="toggle" title="Toggle visibility"><%= e.is_visible ? 'Hide' : 'Show' %></button>
                <button type="button" class="icon-action danger" data-action="delete" title="Delete embed">Del</button>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
    </details>

    <details class="admin-accordion">
      <summary>
        <span>Redirects</span>
        <button type="button" class="btn-secondary create-new-btn" id="redirect-create-btn">Create New</button>
      </summary>
      <section class="card section-card">
        <div class="links-help muted">Manage short slugs quickly. Toggle active state without refreshing.</div>
        <div id="redirects-admin-list" class="links-admin-list" data-csrf="<%= csrfToken %>">
          <% redirects.forEach(r => { %>
            <article
              class="link-admin-item <%= r.is_active ? '' : 'is-hidden-link' %>"
              data-id="<%= r.id %>"
              data-slug="<%= r.slug %>"
              data-url="<%= r.target_url %>"
              data-active="<%= r.is_active ? '1' : '0' %>">
              <button type="button" class="icon-action" title="Slug" aria-label="Slug">/</button>
              <div class="link-admin-main">
                <div class="link-admin-title">/<%= r.slug %></div>
                <a class="link-admin-url" href="<%= r.target_url %>" target="_blank" rel="noopener noreferrer"><%= r.target_url %></a>
              </div>
              <div class="link-admin-meta">
                <span class="link-pill"><%= r.is_active ? 'Active' : 'Inactive' %></span>
              </div>
              <div class="link-admin-actions">
                <button type="button" class="icon-action" data-action="edit" title="Edit redirect">Edit</button>
                <button type="button" class="icon-action" data-action="utm" title="Build tracked URL">Track</button>
                <button type="button" class="icon-action" data-action="toggle" title="Toggle active"><%= r.is_active ? 'Off' : 'On' %></button>
                <button type="button" class="icon-action danger" data-action="delete" title="Delete redirect">Del</button>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
    </details>

    <details class="admin-accordion">
      <summary>
        <span>Analytics</span>
      </summary>
      <section class="card section-card analytics-shell">
        <div class="analytics-toolbar">
          <form method="GET" action="/admin" class="analytics-filter-form">
            <label class="analytics-filter-label">
              Range
              <select name="analytics_days">
                <option value="1" <%= analyticsDays === 1 ? 'selected' : '' %>>Last 24h</option>
                <option value="7" <%= analyticsDays === 7 ? 'selected' : '' %>>Last 7 days</option>
                <option value="30" <%= analyticsDays === 30 ? 'selected' : '' %>>Last 30 days</option>
                <option value="90" <%= analyticsDays === 90 ? 'selected' : '' %>>Last 90 days</option>
                <option value="365" <%= analyticsDays === 365 ? 'selected' : '' %>>Last 365 days</option>
              </select>
            </label>
            <button type="submit" class="btn-secondary">Apply</button>
          </form>
          <div class="analytics-export-actions">
            <a class="btn-secondary analytics-export-link" href="/admin/analytics/export?days=<%= analyticsDays %>&scope=all">Export CSV (All)</a>
            <a class="btn-secondary analytics-export-link" href="/admin/analytics/export?days=<%= analyticsDays %>&scope=link">Links CSV</a>
            <a class="btn-secondary analytics-export-link" href="/admin/analytics/export?days=<%= analyticsDays %>&scope=redirect">Redirects CSV</a>
          </div>
        </div>

        <div class="analytics-metrics-grid">
          <article class="analytics-metric-card">
            <div class="analytics-metric-label">Profile Visits</div>
            <div class="analytics-metric-value"><%= Number(analytics?.total_visits || 0).toLocaleString() %></div>
          </article>
          <article class="analytics-metric-card">
            <div class="analytics-metric-label">Total Clicks</div>
            <div class="analytics-metric-value"><%= Number(analytics?.total_clicks || 0).toLocaleString() %></div>
          </article>
          <article class="analytics-metric-card">
            <div class="analytics-metric-label">Unique Clickers</div>
            <div class="analytics-metric-value"><%= Number(analytics?.unique_clickers || 0).toLocaleString() %></div>
          </article>
          <article class="analytics-metric-card">
            <div class="analytics-metric-label">Overall CTR</div>
            <div class="analytics-metric-value"><%= Number(analytics?.overall_ctr || 0).toFixed(2) %>%</div>
          </article>
          <article class="analytics-metric-card">
            <div class="analytics-metric-label">Link Clicks</div>
            <div class="analytics-metric-value"><%= Number(analytics?.link_clicks || 0).toLocaleString() %></div>
          </article>
          <article class="analytics-metric-card">
            <div class="analytics-metric-label">Redirect Clicks</div>
            <div class="analytics-metric-value"><%= Number(analytics?.redirect_clicks || 0).toLocaleString() %></div>
          </article>
        </div>

        <div class="analytics-grid">
          <article class="analytics-block">
            <h3>Per-Link Performance</h3>
            <div class="analytics-table-wrap">
              <table class="analytics-table">
                <thead>
                  <tr>
                    <th>Link</th>
                    <th>Clicks</th>
                    <th>Unique</th>
                    <th>CTR</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (analytics?.links?.length) { %>
                    <% analytics.links.forEach(row => { %>
                      <tr>
                        <td title="<%= row.url %>"><%= row.title %></td>
                        <td><%= Number(row.clicks || 0).toLocaleString() %></td>
                        <td><%= Number(row.unique_clicks || 0).toLocaleString() %></td>
                        <td><%= Number(row.ctr || 0).toFixed(2) %>%</td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr><td colspan="4" class="analytics-empty">No link clicks in this range yet.</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </article>

          <article class="analytics-block">
            <h3>Redirect Performance</h3>
            <div class="analytics-table-wrap">
              <table class="analytics-table">
                <thead>
                  <tr>
                    <th>Slug</th>
                    <th>Clicks</th>
                    <th>Unique</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (analytics?.redirects?.length) { %>
                    <% analytics.redirects.forEach(row => { %>
                      <tr>
                        <td title="<%= row.target_url %>">/<%= row.slug %></td>
                        <td><%= Number(row.clicks || 0).toLocaleString() %></td>
                        <td><%= Number(row.unique_clicks || 0).toLocaleString() %></td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr><td colspan="3" class="analytics-empty">No redirect clicks in this range yet.</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </article>

          <article class="analytics-block">
            <h3>Referrers</h3>
            <ul class="analytics-list">
              <% if (analytics?.referrers?.length) { %>
                <% analytics.referrers.forEach(row => { %>
                  <li><span><%= row.referrer %></span><strong><%= Number(row.clicks || 0).toLocaleString() %></strong></li>
                <% }) %>
              <% } else { %>
                <li class="analytics-empty">No referrer data yet.</li>
              <% } %>
            </ul>
          </article>

          <article class="analytics-block">
            <h3>Devices</h3>
            <ul class="analytics-list">
              <% if (analytics?.devices?.length) { %>
                <% analytics.devices.forEach(row => { %>
                  <li><span><%= row.device_type %></span><strong><%= Number(row.clicks || 0).toLocaleString() %></strong></li>
                <% }) %>
              <% } else { %>
                <li class="analytics-empty">No device data yet.</li>
              <% } %>
            </ul>
          </article>

          <article class="analytics-block">
            <h3>Countries</h3>
            <ul class="analytics-list">
              <% if (analytics?.countries?.length) { %>
                <% analytics.countries.forEach(row => { %>
                  <li><span><%= row.country %></span><strong><%= Number(row.clicks || 0).toLocaleString() %></strong></li>
                <% }) %>
              <% } else { %>
                <li class="analytics-empty">No country data yet.</li>
              <% } %>
            </ul>
          </article>

          <article class="analytics-block">
            <h3>Cities</h3>
            <ul class="analytics-list">
              <% if (analytics?.cities?.length) { %>
                <% analytics.cities.forEach(row => { %>
                  <li><span><%= row.city %></span><strong><%= Number(row.clicks || 0).toLocaleString() %></strong></li>
                <% }) %>
              <% } else { %>
                <li class="analytics-empty">No city data yet.</li>
              <% } %>
            </ul>
          </article>

          <article class="analytics-block analytics-block-wide">
            <h3>Time of Day</h3>
            <ul class="analytics-list analytics-list-time">
              <% if (analytics?.time_of_day?.length) { %>
                <% analytics.time_of_day.forEach(row => { %>
                  <li><span><%= row.label %></span><strong><%= Number(row.clicks || 0).toLocaleString() %></strong></li>
                <% }) %>
              <% } else { %>
                <li class="analytics-empty">No hourly data yet.</li>
              <% } %>
            </ul>
          </article>

          <article class="analytics-block analytics-block-wide">
            <h3>UTM Campaign Breakdown</h3>
            <div class="analytics-table-wrap">
              <table class="analytics-table">
                <thead>
                  <tr>
                    <th>Source</th>
                    <th>Medium</th>
                    <th>Campaign</th>
                    <th>Clicks</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (analytics?.utm?.length) { %>
                    <% analytics.utm.forEach(row => { %>
                      <tr>
                        <td><%= row.source %></td>
                        <td><%= row.medium %></td>
                        <td><%= row.campaign %></td>
                        <td><%= Number(row.clicks || 0).toLocaleString() %></td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr><td colspan="4" class="analytics-empty">No UTM-tagged traffic yet.</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </article>
        </div>
      </section>
    </details>
  </div>

  <div id="admin-modal-overlay" class="modal-overlay" hidden>
    <div class="modal-shell">
      <section id="link-modal" class="modal-card" hidden>
        <div class="modal-header">
          <h3 id="link-modal-title">Create Link</h3>
          <button type="button" class="icon-action" data-modal-close aria-label="Close">✕</button>
        </div>
        <form id="link-modal-form" class="modal-form">
          <input type="hidden" name="id" id="link-modal-id">
          <div class="modal-grid modal-grid-2">
            <label class="modal-field">
              <span class="modal-label">Title</span>
              <input name="title" id="link-modal-title-input" required>
            </label>
            <label class="modal-field">
              <span class="modal-label">URL</span>
              <input name="url" id="link-modal-url" type="url" required>
            </label>
            <label class="modal-field">
              <span class="modal-label">Icon key</span>
              <select name="icon_key" id="link-modal-icon">
                <option value="">(none)</option>
                <% icons.forEach(i => { %>
                  <option value="<%= i %>"><%= i %></option>
                <% }) %>
              </select>
            </label>
            <div id="link-modal-icon-preview" class="icon-key-preview" aria-live="polite">
              <div class="icon-key-preview-chip">
                <img id="link-modal-icon-preview-image" src="" alt="" hidden>
                <span id="link-modal-icon-preview-fallback" class="icon-key-preview-fallback">?</span>
              </div>
              <div class="icon-key-preview-meta">
                <div class="icon-key-preview-title">Icon Preview</div>
                <div id="link-modal-icon-preview-label" class="icon-key-preview-label">No icon selected</div>
              </div>
            </div>
            <label class="modal-field">
              <span class="modal-label">Button color</span>
              <div class="inline-color-picker">
                <input name="color_hex" id="link-modal-color" class="color-input" type="color" value="#2a2a2a">
                <span id="link-modal-color-preview" class="color-chip color-chip-lg" title="#2a2a2a"></span>
              </div>
            </label>
          </div>
          <label class="checkbox modal-checkbox"><input type="checkbox" name="is_visible" id="link-modal-visible" checked> Visible</label>
          <p class="modal-hint">Tip: use Icon key to match your link platform. You can still save without an icon.</p>
          <div class="modal-actions">
            <button type="submit">Save Link</button>
            <button type="button" class="btn-secondary" data-modal-close>Cancel</button>
          </div>
        </form>
      </section>

      <section id="embed-modal" class="modal-card" hidden>
        <div class="modal-header">
          <h3 id="embed-modal-title">Create Embed</h3>
          <button type="button" class="icon-action" data-modal-close aria-label="Close">✕</button>
        </div>
        <form id="embed-modal-form" class="modal-form">
          <input type="hidden" name="id" id="embed-modal-id">
          <label class="modal-field">
            <span class="modal-label">Title</span>
            <input name="title" id="embed-modal-title-input" required>
          </label>
          <label class="modal-field">
            <span class="modal-label">Embed HTML</span>
            <textarea name="embed_html" id="embed-modal-html" rows="6" required></textarea>
          </label>
          <label class="checkbox modal-checkbox"><input type="checkbox" name="is_visible" id="embed-modal-visible" checked> Visible</label>
          <p class="modal-hint">Only trusted HTTPS iframe embeds are allowed (YouTube, Twitch, TikTok, Spotify).</p>
          <div class="modal-actions">
            <button type="submit">Save Embed</button>
            <button type="button" class="btn-secondary" data-modal-close>Cancel</button>
          </div>
        </form>
      </section>

      <section id="redirect-modal" class="modal-card" hidden>
        <div class="modal-header">
          <h3 id="redirect-modal-title">Create Redirect</h3>
          <button type="button" class="icon-action" data-modal-close aria-label="Close">✕</button>
        </div>
        <form id="redirect-modal-form" class="modal-form">
          <input type="hidden" name="id" id="redirect-modal-id">
          <div class="modal-grid modal-grid-2">
            <label class="modal-field">
              <span class="modal-label">Slug</span>
              <input name="slug" id="redirect-modal-slug" placeholder="portfolio" pattern="[a-z0-9_-]{1,80}" required>
            </label>
            <label class="modal-field">
              <span class="modal-label">Target URL</span>
              <input name="target_url" id="redirect-modal-url" type="url" placeholder="https://..." required>
            </label>
          </div>
          <label class="checkbox modal-checkbox"><input type="checkbox" name="is_active" id="redirect-modal-active" checked> Active</label>
          <p class="modal-hint">Slugs are lowercase and become available at <code>/your-slug</code>.</p>
          <div class="modal-actions">
            <button type="submit">Save Redirect</button>
            <button type="button" class="btn-secondary" data-modal-close>Cancel</button>
          </div>
        </form>
      </section>

      <section id="utm-modal" class="modal-card" hidden>
        <div class="modal-header">
          <h3 id="utm-modal-title">Tracked Link Builder</h3>
          <button type="button" class="icon-action" data-modal-close aria-label="Close">✕</button>
        </div>
        <form id="utm-modal-form" class="modal-form" onsubmit="return false;">
          <label class="modal-field">
            <span class="modal-label">Base tracking URL</span>
            <input id="utm-base-url" type="text" readonly>
          </label>
          <div class="modal-grid modal-grid-2">
            <label class="modal-field">
              <span class="modal-label">UTM Source</span>
              <input id="utm-source" name="utm_source" placeholder="instagram">
            </label>
            <label class="modal-field">
              <span class="modal-label">UTM Medium</span>
              <input id="utm-medium" name="utm_medium" placeholder="bio">
            </label>
            <label class="modal-field">
              <span class="modal-label">UTM Campaign</span>
              <input id="utm-campaign" name="utm_campaign" placeholder="spring-launch">
            </label>
            <label class="modal-field">
              <span class="modal-label">UTM Term</span>
              <input id="utm-term" name="utm_term" placeholder="optional">
            </label>
          </div>
          <label class="modal-field">
            <span class="modal-label">UTM Content</span>
            <input id="utm-content" name="utm_content" placeholder="button-a">
          </label>
          <label class="modal-field">
            <span class="modal-label">Tracked URL</span>
            <input id="utm-result-url" type="text" readonly>
          </label>
          <p id="utm-copy-status" class="modal-hint">Build a campaign URL and copy it in one click.</p>
          <div class="modal-actions">
            <button type="button" id="utm-copy-btn">Copy Tracked Link</button>
            <button type="button" class="btn-secondary" data-modal-close>Done</button>
          </div>
        </form>
      </section>
    </div>
  </div>

  <script src="/static/js/admin.js" defer></script>
</body>

</html>
