<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title || 'Protected Content' %></title>
  <link rel="stylesheet" href="/static/css/site.css">
</head>

<body data-age-verified="<%= ageVerified ? '1' : '0' %>" data-continue-url="<%= continueUrl || returnTo %>">
  <main class="auth-container">
    <section class="form cardy">
      <h1><%= title || 'Protected Content' %></h1>
      <% if (subtitle) { %>
        <p class="muted"><%= subtitle %></p>
      <% } %>

      <% if (mode === 'age') { %>
        <% if (ageVerified) { %>
          <p id="age-redirect-status" class="muted small">Please wait while we redirect you...</p>
          <p id="age-redirect-fallback" class="muted small" hidden>Redirect taking longer than expected?</p>
          <a id="age-continue-link" class="btn-secondary" href="<%= continueUrl || returnTo %>" hidden>Click here to go to your link</a>
          <noscript>
            <p class="muted small">JavaScript is disabled.</p>
            <a class="btn-secondary" href="<%= continueUrl || returnTo %>">Click here to go to your link</a>
          </noscript>
        <% } else { %>
          <form method="POST" action="/access/age-verify">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="return_to" value="<%= returnTo %>">
            <input type="hidden" name="context_type" value="<%= contextType %>">
            <input type="hidden" name="context_id_or_slug" value="<%= contextIdOrSlug %>">
            <p class="muted small">Confirm your age to continue.</p>
            <button type="submit">I am 18 or over</button>
          </form>
        <% } %>
      <% } else { %>
        <form method="POST" action="/access/password-unlock">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="context_type" value="<%= contextType %>">
          <input type="hidden" name="context_id_or_slug" value="<%= contextIdOrSlug %>">
          <input type="hidden" name="return_to" value="<%= returnTo %>">
          <label>Password
            <input name="password" type="password" minlength="6" maxlength="128" autocomplete="current-password" required>
          </label>
          <button type="submit">Unlock</button>
        </form>
      <% } %>
    </section>
  </main>
  <% if (mode === 'age' && ageVerified) { %>
    <script src="/static/js/access_gate.js" defer></script>
  <% } %>
</body>

</html>
